  {
    "type": "group",
    "name": "promotion",
    "label": "Promoción temporal",
    "children": [
      {
        "id": "promotion.enabled",
        "type": "boolean",
        "name": "enabled",
        "label": "Activar promoción",
        "default": true
      },
      {
        "id": "promotion.banner_prefix",
        "type": "text",
        "name": "banner_prefix",
        "label": "Prefijo del banner",
        "default": "Promoción por tiempo limitado"
      },
      {
        "id": "promotion.discount_percent",
        "type": "number",
        "name": "discount_percent",
        "label": "Descuento (%)",
        "min": 0,
        "max": 99.99,
        "step": 0.01,
        "default": 50
      },
      {
        "id": "promotion.duration_months",
        "type": "number",
        "name": "duration_months",
        "label": "Duración (meses)",
        "min": 1,
        "max": 36,
        "step": 1,
        "default": 6
      },
      {
        "id": "promotion.status_label",
        "type": "text",
        "name": "status_label",
        "label": "Etiqueta de estado",
        "default": "OFERTA ACTIVA"
      }
    ]
  },
  {
    "type": "text",
    "name": "pricing_note",
    "label": "Nota de precio",
    "default": "Precios mensuales, sin impuestos incluidos."
  },
  {
    "type": "text",
    "name": "cta_label",
    "label": "CTA",
    "default": "Solicitar demo"
  },
  {
    "type": "text",
    "name": "cta_anchor",
    "label": "Anchor CTA",
    "default": "#demo-form"
  },
  {
    "type": "text",
    "name": "footnote",
    "label": "Cintillo inferior",
    "allow_new_line": true,
    "default": "Desde cualquier plan puedes contratar bolsas de tokens adicionales. Los tokens adicionales se consumen solo cuando se agotan los tokens mensuales del plan contratado."
  },
  {
