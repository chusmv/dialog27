{
  "name": "dialog27-docs-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "hubspot:css:build": "tailwindcss -i hubspot/src/theme.css -o hubspot/d27-docs-theme/css/main.css --minify",
    "hubspot:css:watch": "tailwindcss -i hubspot/src/theme.css -o hubspot/d27-docs-theme/css/main.css --watch",
    "hubspot:upload": "npm run hubspot:css:build && hs upload hubspot/d27-docs-theme d27-docs-theme",
    "hubspot:watch": "hs watch hubspot/d27-docs-theme d27-docs-theme",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
